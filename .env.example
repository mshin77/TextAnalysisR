# TextAnalysisR Environment Variables
# Copy this file to .env and fill in your keys.
# The .env file is gitignored and will not be committed.

# OpenAI API key (for GPT-4 vision, embeddings, topic labeling, sentiment)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key (for Gemini vision, embeddings, topic labeling, sentiment)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=
